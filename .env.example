# OpenRouter API key — required
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Model for the outer CodeMode agent (default: minimax/minimax-m3)
OPENROUTER_MODEL=minimax/minimax-m3

# Model for the inner llm_query() classifier agent; can differ from outer model
OPENROUTER_INNER_MODEL=minimax/minimax-m3

# Braintrust observability — API key and project name
BRAINTRUST_API_KEY=your-braintrust-api-key-here
BRAINTRUST_PROJECT=aiid-explorer

# Outer loop iteration count (default: 10)
MAX_ROUNDS=10

# Round at which topic steering activates via LDA over past search queries (default: 5).
# Set to "none" to disable steering entirely — all rounds use the verbatim user query.
# Backend-only setting; not exposed in the Gradio UI.
STEERING_ROUND=5

# Max CodeMode code-block executions per harness call (default: 5)
STOP_AFTER_N_CALLS=5

# Max consecutive has_new_incidents rejections before skipping a round (default: 3)
MAX_VALIDATOR_RETRIES=3

# Max incidents returned per aiid_search() call (default: 20)
AIID_RESULTS_LIMIT=20
